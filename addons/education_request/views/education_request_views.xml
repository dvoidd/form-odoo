<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_education_request_form" model="ir.ui.view">
        <field name="name">education.request.form</field>
        <field name="model">education.request</field>
        <field name="arch" type="xml">
            <form string="Pengajuan Pendidikan &amp; Pelatihan">
                <sheet>
                    <div class="oe_title">
                        <label for="document_number" class="oe_edit_only"/>
                        <h1>
                            <field name="document_number" placeholder="Contoh: 001/HRD/2026"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="request_date"/>
                            <field name="applicant_name"/>
                            <field name="applicant_dept"/>
                        </group>
                        <group>
                            <field name="training_name"/>
                            <field name="provider_name"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="location"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Daftar Peserta">
                            <field name="participant_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="employee_id"/>
                                    <field name="position"/>
                                    <field name="department"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_education_request_list" model="ir.ui.view">
        <field name="name">education.request.list</field>
        <field name="model">education.request</field>
        <field name="arch" type="xml">
            <list string="Daftar Pengajuan">
                <field name="document_number"/>
                <field name="training_name"/>
                <field name="applicant_name"/>
                <field name="request_date"/>
            </list>
        </field>
    </record>

    <record id="action_education_request" model="ir.actions.act_window">
        <field name="name">Formulir Diklat</field>
        <field name="res_model">education.request</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_education_request_root" name="Pendidikan &amp; Pelatihan" sequence="15"/>
    <menuitem id="menu_education_request_form" name="Formulir Pengajuan" parent="menu_education_request_root" action="action_education_request" sequence="10"/>

</odoo>