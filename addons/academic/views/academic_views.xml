<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_academic_course_form" model="ir.ui.view">
        <field name="name">academic.course.form</field>
        <field name="model">academic.course</field>
        <field name="arch" type="xml">
            <form string="Course">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Course Title..."/></h1>
                    </div>
                    <group>
                        <field name="responsible_id"/>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Sessions">
                            <field name="session_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="start_date"/>
                                    <field name="duration"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_academic_course_list" model="ir.ui.view">
        <field name="name">academic.course.list</field>
        <field name="model">academic.course</field>
        <field name="arch" type="xml">
            <list string="Courses">
                <field name="name"/>
                <field name="responsible_id"/>
            </list>
        </field>
    </record>

    <record id="view_academic_session_form" model="ir.ui.view">
        <field name="name">academic.session.form</field>
        <field name="model">academic.session</field>
        <field name="arch" type="xml">
            <form string="Session">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="course_id"/>
                            <field name="instructor_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="duration"/>
                            <field name="seats"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>



    <record id="action_academic_course" model="ir.actions.act_window">
        <field name="name">Courses</field>
        <field name="res_model">academic.course</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_academic_session" model="ir.actions.act_window">
        <field name="name">Sessions</field>
        <field name="res_model">academic.session</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_academic_session_tree"/>
    </record>

    <menuitem id="menu_academic_root" name="Academic" sequence="10"/>
    
    <menuitem id="menu_academic_course" name="Courses" parent="menu_academic_root" action="action_academic_course" sequence="10"/>
    <menuitem id="menu_academic_session" name="Sessions" parent="menu_academic_root" action="action_academic_session" sequence="20"/>
</odoo>